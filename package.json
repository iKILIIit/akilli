{
  "name": "minipay-yield-copilot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @yield-copilot/miniapp --filter @yield-copilot/api dev",
    "dev:miniapp": "pnpm --filter @yield-copilot/miniapp dev",
    "dev:api": "pnpm --filter @yield-copilot/api dev",
    "start:miniapp": "pnpm --filter @yield-copilot/miniapp start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  }
}
