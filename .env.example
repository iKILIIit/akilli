NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_DEFAULT_CHAIN=celo
NEXT_PUBLIC_MINIPAY_ONLY=false
NEXT_PUBLIC_SUPPORT_EMAIL=support@akili.app
API_BASE_URL=http://localhost:3000
PORT=3000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LINKUP_API_KEY=

# x402 micropayment gating (optional — set both to require 0.01 USDC per AI analysis)
THIRDWEB_SECRET_KEY=
AGENT_PAYMENT_RECIPIENT=

# Contract deployment & ERC-8004 agent registration
# Private key WITHOUT 0x prefix — used by Hardhat deploy and register-erc8004 script
DEPLOYER_PRIVATE_KEY=
# Agent metadata URI — defaults to https://minipay-yield-decision-agent.vercel.app/agent.json
AGENT_URI=
